  <img src="https://mintcdn.com/chatbase/8UJvGeL1-PrFP--v/user-guides/chatbot/images/model-comparison/kimi-k2.png?fit=max&auto=format&n=8UJvGeL1-PrFP--v&q=85&s=97a8263210ab5b8934bf6233905771dc" alt="Chatbase Embed Code Example" width="6084" height="3780" data-path="user-guides/chatbot/images/model-comparison/kimi-k2.png" />
